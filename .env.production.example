# =========================================================
# Nexa SMM Panel - Production Environment Template
# IMPORTANT: Never commit real secrets. Keep this file as template only.
# =========================================================

# Core app
APP_NAME="Nexa SMM Panel"
PROJECT_NAME="Nexa Midia Solution"
ENVIRONMENT="production"
TIMEZONE="Asia/Kolkata"
DEFAULT_LANGUAGE="hinglish"
ALLOWED_COUNTRY_CODES="IN"

# Telegram bot
TELEGRAM_BOT_DISPLAY_NAME="Nexa SMM Panel"
TELEGRAM_BOT_USERNAME="NexaNo1SMMBot"
TELEGRAM_BOT_TOKEN="REPLACE_WITH_REAL_BOT_TOKEN"
TELEGRAM_SUPPORT_USERNAME="NexaNo1Support"
TELEGRAM_UPDATES_CHANNEL="https://t.me/NexaNo1Updates"
TELEGRAM_DISCUSSION_GROUP="@NexaCommunity"
TELEGRAM_FORCE_JOIN_ENABLED="true"
TELEGRAM_FORCE_JOIN_FLOW="channel,group,bot"

# Telegram admins
SUPER_ADMIN_IDS="6646320334"
ADMIN_USERNAMES="@NexaNo1Support"
ADMIN_2FA_ENABLED="true"

# Security
APP_SECRET_KEY="REPLACE_WITH_LONG_RANDOM_SECRET"
JWT_SECRET_KEY="REPLACE_WITH_LONG_RANDOM_SECRET"
WEBHOOK_SIGNATURE_SECRET="REPLACE_WITH_WEBHOOK_SECRET"
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_KEY_BASE64"

# Cashfree (ONLY gateway enabled)
PAYMENT_GATEWAY="cashfree"
CASHFREE_MODE="LIVE"
CASHFREE_APP_ID="104929343d4e4107a5ca08529a03929401"
CASHFREE_SECRET_KEY="REPLACE_WITH_REAL_CASHFREE_SECRET"
CASHFREE_WEBHOOK_SECRET="REPLACE_WITH_SEPARATE_WEBHOOK_SECRET"
CASHFREE_WEBHOOK_URL="https://yourdomain.com/api/cashfree/webhook"
MIN_ADD_MONEY_INR="100"
AUTO_CREDIT_ON_WEBHOOK="true"

# Wallet and finance
WALLET_CURRENCY="INR"
WALLET_TRANSACTION_FEE_HANDLING="user_bear"
FAILED_ORDER_AUTO_REFUND="true"
WALLET_MANUAL_ADJUSTMENT_BY_ADMIN="true"

# Providers
PROVIDER_1_NAME="JustAnotherPanel"
PROVIDER_1_BASE_URL="https://justanotherpanel.com/api/v2"
PROVIDER_1_API_KEY="REPLACE_WITH_PROVIDER1_KEY"
PROVIDER_1_PRIORITY="1"
PROVIDER_1_FALLBACK_ALLOWED="true"

PROVIDER_2_NAME="Peakerr API"
PROVIDER_2_BASE_URL="https://peakerr.com/api/v2"
PROVIDER_2_API_KEY="REPLACE_WITH_PROVIDER2_KEY"
PROVIDER_2_PRIORITY="2"
PROVIDER_2_FALLBACK_ALLOWED="true"

# Pricing & growth
DEFAULT_MARKUP_PERCENT="25"
MARKUP_INSTAGRAM_FOLLOWERS="20"
MARKUP_INSTAGRAM_LIKES="25"
MARKUP_YOUTUBE_VIEWS="30"
MARKUP_TELEGRAM_MEMBERS="20"
COUPONS_ENABLED="true"
REFERRAL_ENABLED="true"
REFERRAL_PERCENT="5"
VIP_SILVER_DISCOUNT_PERCENT="2"
VIP_GOLD_DISCOUNT_PERCENT="5"
VIP_PLATINUM_DISCOUNT_PERCENT="10"

# Compliance
BLOCKED_WORDS="spam,abuse,hack,fraud"
ABUSE_POLICY="warn_then_instant_ban_on_repeat"
UNBAN_REQUEST_TEMPLATE="Hello admin, mera account galti se block ho gaya hai. Kindly review."
KYC_REQUIRED="false"

# Infra
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
REDIS_URL="redis://HOST:6379/0"
DOMAIN="panel.nexamediasolution.in"
SSL_PROVIDER="cloudflare"

# Jobs
ENABLE_CRON_JOBS="true"
ORDER_STATUS_SYNC_CRON="*/2 * * * *"
PROVIDER_HEALTH_SYNC_CRON="*/5 * * * *"
AUTO_SERVICE_SYNC_CRON="0 */3 * * *"
AUTO_PRICE_UPDATE_CRON="15 */3 * * *"

# Notifications
ADMIN_TELEGRAM_ALERTS="new_order,failed_payment,provider_failure,abuse_reports"
EMAIL_ALERTS_ENABLED="false"
WHATSAPP_ALERTS_ENABLED="false"

# Cron runner
CRON_SYNC_SERVICES_ENABLED="true"
CRON_ORDER_STATUS_SYNC_ENABLED="true"
CRON_REFUND_FAILED_ENABLED="true"
